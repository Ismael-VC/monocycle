|20 @Screen &vector $2 &width $2 &height $2 &auto $1 &pad $1 &x $2 &y $2 &addr $2 &pixel $1 &sprite $1

|0100 ( -> )

	;hello-word print-text
	LIT "? #18 DEO

	#0180
		DUP2 .Screen/width DEO2
		.Screen/height DEO2

BRK

@print-text ( str* -- )

	&while
		( send ) LDAk #18 DEO
		( loop ) INC2 LDAk ,&while JCN
	POP2

JMP2r

@hello-word "Hello 20 "World! 00

