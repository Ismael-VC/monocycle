|00 @System &vector $2 &pad $6 &r $2 &g $2 &b $2
|10 @Console &vector $2 &read $1 &pad $5 &write $1
|20 @Screen &vector $2 &width $2 &height $2 &auto $1 &pad $1 &x $2 &y $2 &addr $2 &pixel $1 &sprite $1
|80 @Controller &vector $2 &button $1 &key $1
|90 @Mouse &vector $2 &x $2 &y $2 &state $1 &chord $1
|a0 @File &vector $2 &success $2 &stat $2 &delete $1 &append $1 &name $2 &length $2 &read $2 &write $2

|0000

	( system )
	@emu &sleep $1 &rate $1 &time $2 &length $2
	@uxn &pc $2 &src $2 &dst $2 &err $1 &2 $1
	( buffers )
	@console-buf $80

|0100

	( theme )
	#f05a .System/r DEO2
	#f0ba .System/g DEO2
	#f0aa .System/b DEO2
	( size )
	#01c0 .Screen/width DEO2
	#00a0 .Screen/height DEO2
	( mode )
	#15 .Screen/auto DEO
	redraw

	( unlock )
	;on-console .Console/vector DEO2
	;on-mouse .Mouse/vector DEO2

BRK

@on-mouse ( -> )

	[ LIT2 00 -Mouse/state ] DEI NEQ #41 ADD ;cursor-icn update-cursor

	.Mouse/state DEI ?&on-mouse-down

BRK

&on-mouse-down ( -> )

	( TODO: )

BRK

@on-console ( -> )

	.Console/read DEI
	DUP ?&append
	!&eval

&append ( c -- )

	( convert invisible chars to spaces )
	#20 GTHk [ JMP SWP POP ]
	( if last char was space, skip )
	DUP #20 NEQ OVR [ LIT &last 20 ] NEQ ORA ?&no-dup
		POP BRK &no-dup
	DUP ,&last STR
	( append )
	[ LIT2 &ptr =source ] STH2k STA
	INC2r STH2r ,&ptr STR2

BRK

&eval ( char -> )

	POP #0a ,&ptr LDR2 STA
	( pre cleanup )
	;rom .emu/length LDZ2 mclr
	;console-buf sclr
	( parse )
	assemble
	;write/head LDA2 .emu/length STZ2
	( let's go! )
	draw-clear
	run
	redraw
	( cleanup )
	;source
		DUP2 ;&ptr STA2
		sclr

BRK

@run ( -- )

	reset
	#00 .emu/sleep STZ
	#f000
	&w
		step
		.uxn/err LDZ ?&err
		.emu/sleep LDZ ?&end
		INC2 ORAk ?&w
	&end
	POP2

JMP2r
	&err POP2
	( reset ptrs )
	#00 ;wst/ptr STA
	#00 ;rst/ptr STA

JMP2r

@send ( v* p* -- )

	NIP
	DUP #0e NEQ ?&no-debug
		;dict/breakpoint draw-event
		&no-debug
	DUP #0f NEQ ?&no-halt
		;dict/halt draw-event
		&no-halt
	DUP #18 NEQ ?&no-console
		OVR append-char
		&no-console
	POP POP2

JMP2r

@append-char ( char -- )

	;console-buf
	DUP2 slen #007f LTH2 ?&continue
		DUP2 sclr
		&continue

!sput

(
@|drawing )

@redraw ( -- )

	#0010
		DUP2 .Screen/x DEO2
		.Screen/y DEO2

	draw-console
	draw-error
	draw-stacks
	draw-spacer

!draw-asm

@draw-clear ( -- )

	#91 .Screen/auto DEO
	#00 .Screen/width DEI2 #03 SFT2 NIP SUB DUP
	#0000 .Screen/x DEO2
	#0000 .Screen/y DEO2
		&above #00 .Screen/sprite DEO INC DUP ?&above POP
	#0000 .Screen/x DEO2
	#0050 .Screen/y DEO2
		&below #00 .Screen/sprite DEO INC DUP ?&below POP
	#15 .Screen/auto DEO

JMP2r

@draw-stacks ( -- )

	( ws )
	#0010 .Screen/x DEO2
	.Screen/height DEI2 #0028 SUB2 .Screen/y DEO2
	;dict/ws #03 draw-str-color
	;wst draw-stack
	( rs )
	#0010 .Screen/x DEO2
	.Screen/height DEI2 #0018 SUB2 .Screen/y DEO2
	;dict/rs #03 draw-str-color
	;rst

@draw-stack ( stack* -- )

	DUP2 #00fe ADD2 LDA
		DUP ,&sp STR
	?&no-new
		POP2 ;dict/empty #01 !draw-str-color
		&no-new

	STH2
	#2000
	&loop
		( highlight )
		INCk [ LIT &sp $1 ] EQU STH
			#0201 STHr [ JMP SWP POP ] ;draw-char/color STA
		( end )
		DUP ,&sp LDR LTH ?&no-empty
			POP2 POP2r JMP2r
			&no-empty
		( byte )
		#00 OVR STH2kr ADD2 LDA draw-byte #20 draw-char
		INC GTHk ?&loop
	POP2
	POP2r

JMP2r

@draw-console ( -- )

	#0010 .Screen/x DEO2
	.Screen/height DEI2 #0048 SUB2 .Screen/y DEO2
	;dict/console #03 draw-str-color
	;console-buf #01

!draw-str-color

@draw-error ( -- )

	#0010 .Screen/x DEO2
	.Screen/height DEI2 #0038 SUB2 .Screen/y DEO2
	;dict/error #03 draw-str-color
	#00 .uxn/err LDZ DUP ADD ;errors ADD2 LDA2 #01

!draw-str-color

@draw-asm ( -- )

	#0010 .Screen/x DEO2
	#0030 .Screen/y DEO2
	#01 ;draw-char/color STA
	;write/length LDA2 #0000 EQU2 ?&ready

	;dict/assembled-in draw-str
	;write/length LDA2 #00ff SUB2 draw-dec
	;dict/bytes draw-str

	( draw time )
	;dict/completed-in draw-str
	.emu/time LDZ2 draw-dec
	;dict/cycles draw-str

	( draw code )
	#0010 .Screen/x DEO2
	#0010 .Screen/y DEO2
	;source
	&w
		.Screen/x DEI2 .Screen/width DEI2 #0010 SUB2 GTH2 ?&e-tal
		LDAk draw-char
		INC2 LDAk ?&w
	&e-tal
	POP2

	( draw assembled )
	#0010 .Screen/x DEO2
	#0020 .Screen/y DEO2
	;write/length LDA2 #00ff SUB2 #0000
	&l
		DUP2 ;rom/reset ADD2 LDA draw-byte #20 draw-char
		.Screen/x DEI2 .Screen/width DEI2 #0010 SUB2 GTH2 ?&e-asm
		INC2 GTH2k ?&l
	&e-asm
	POP2 POP2

JMP2r

&ready

	;dict/ready #01

!draw-str-color

@draw-byte ( byte -- )

	DUP #04 SFT draw-hex

@draw-hex ( char -- )

	#0f AND DUP #09 GTH #27 MUL ADD #30 ADD

@draw-char ( char -- )

	#20 SUB #00 SWP
		DUP2 #50 SFT2 ;font/glyphs ADD2 .Screen/addr DEO2
		;font ADD2 LDA #00 SWP .Screen/x DEI2 ADD2
	[ LIT &color 01 ] .Screen/sprite DEOk DEO
	.Screen/x DEO2

JMP2r

@draw-dec ( short* -- )

	#00 ,&z STR
	( sign )
	DUP2 #4000 AND2 #0000 EQU2 ?&positive
		LIT "- draw-char #4000 SWP2 SUB2 #3fff AND2
		&positive
	#2710 draw-dec/parse
	#03e8 draw-dec/parse
	#0064 draw-dec/parse
	#000a draw-dec/parse
	NIP #30 ADD !draw-char ( .. )

	&parse
		DIV2k DUPk [ LIT &z $1 ] EQU ?&skip
		DUP #30 ADD draw-char #ff ,&z STR
		&skip POP MUL2 SUB2
	JMP2r

@draw-event ( str* -- )

	!pstr

@draw-str-color ( str* color -- )

	;draw-char/color STA

@draw-str ( str* -- )

	#15 .Screen/auto DEO
	&while
		LDAk draw-char
		INC2 LDAk ?&while
	POP2

JMP2r

@update-cursor ( color addr* -- )

	[ LIT2 00 -Screen/auto ] DEO
	#40 draw-cursor
	.Mouse/x DEI2 ,draw-cursor/x STR2
	.Mouse/y DEI2 ,draw-cursor/y STR2
	.Screen/addr DEO2

@draw-cursor ( color -- )

	[ LIT2 &x $2 ] .Screen/x DEO2
	[ LIT2 &y $2 ] .Screen/y DEO2
	.Screen/sprite DEO

JMP2r

@draw-spacer ( -- )

	#0000 .Screen/x DEO2
	.Screen/height DEI2 #0058 SUB2 .Screen/y DEO2
	;jagged-icn .Screen/addr DEO2
	#01 .Screen/auto DEO
	#00 .Screen/width DEI2 #03 SFT2 NIP SUB
	&l
		#01 .Screen/sprite DEO
		INC DUP ?&l
	POP
	#15 .Screen/auto DEO

JMP2r


(
@|stdlib )

	@mclr ( src* len* -- ) OVR2 ADD2 SWP2 &l STH2k #00 STH2r STA INC2 GTH2k ?&l POP2 POP2 JMP2r
	@scap ( str* -- end* ) LDAk ?&w JMP2r &w INC2 LDAk ?&w JMP2r
	@sput ( chr str* -- ) scap INC2k #00 ROT ROT STA STA JMP2r
	@slen ( str* -- len* ) DUP2 scap SWP2 SUB2 JMP2r
	@scat ( src* dst* -- ) scap
	@scpy ( src* dst* -- ) OVR2 LDA ?&e POP2 POP2 JMP2r &e STH2 &w LDAk STH2kr STA INC2r INC2 LDAk ?&w POP2 #00 STH2r STA JMP2r
	@sclr ( str* -- ) LDAk ?&w POP2 JMP2r &w STH2k #00 STH2r STA INC2 LDAk ?&w POP2 JMP2r
	@scmp ( a* b* -- f ) STH2 &l LDAk LDAkr STHr ANDk #00 EQU ?&e NEQk ?&e POP2 INC2 INC2r !&l &e NIP2 POP2r EQU JMP2r
	@scmp3 ( a* b* -- f ) LDA2k ROT2 LDA2k ROT2 EQU2 STH INC2 LDA2 SWP2 INC2 LDA2 EQU2 STHr AND JMP2r
	@chex ( c -- val|ff ) LIT "0 SUB DUP #09 GTH [ JMP JMP2r ] #27 SUB DUP #0f GTH [ JMP JMP2r ] POP #ff JMP2r
	@shex ( str* -- val* ) LIT2r 0000 &w LITr 40 SFT2r LITr 00 LDAk chex STH ADD2r INC2 LDAk ?&w POP2 STH2r JMP2r
	@pstr ( str* -- ) LDAk ?&w POP2 JMP2r &w LDAk #19 DEO INC2 LDAk ?&w POP2 JMP2r
	@phex ( short* -- ) SWP phex/b &b ( byte -- ) DUP #04 SFT phex/c &c ( char -- ) #0f AND DUP #09 GTH #27 MUL ADD #30 ADD #18 DEO JMP2r

~src/asm.tal

